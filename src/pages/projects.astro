---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: "Color Improv",
    href: "https://colorimprov.alexfang.me",
    description: "An educational web app that teaches how to improvise on the 12-bar blues in a fun and interactive way.",
  },
];
---

<BaseLayout title="Projects — Alex Fang" description="Projects by Alex Fang.">
  <h1>Projects</h1>

  <ul class="project-list">
    {projects.map((project) => (
      <li>
        <a href={project.href} target="_blank" rel="noopener noreferrer">
          {project.name}
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="7" y1="17" x2="17" y2="7" />
            <polyline points="7 7 17 7 17 17" />
          </svg>
        </a>
        <p>{project.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--clr-fg);
    margin-bottom: 2rem;
  }

  .project-list {
    list-style: none;
  }

  .project-list li {
    padding: 1.25rem 0;
    border-top: 1px solid var(--clr-border);
  }

  .project-list li a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--clr-accent);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .project-list li a:hover {
    opacity: 0.7;
  }

  .project-list li a svg {
    transition: transform 0.2s ease;
  }

  .project-list li a:hover svg {
    transform: translate(2px, -2px);
  }

  .project-list li p {
    margin-top: 0.4rem;
    font-size: 0.95rem;
    color: var(--clr-fg-muted);
    line-height: 1.6;
  }
</style>
